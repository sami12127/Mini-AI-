  {
   "cell_type": "code",
   "execution_count": null,
   "id": "3e563226",
   "metadata": {},
   "outputs": [],
   "source": [
    "print(\"Loading set\")\n",
    "(x_train, y_train), (x_test, y_test) = mnist.load_data()\n",
    "x_train = x_train.astype('float32') / 255.0\n",
    "x_test = x_test.astype('float32') / 255.0\n",
    "print(\"Loaded\")\n",
    "\n",
    "total_mean = np.mean(x_train)\n",
    "total_std = np.std(x_train)\n",
    "print(f\"Totale gemiddelde pixelwaarde: {total_mean:.4f}\")\n",
    "print(f\"Totale standaardafwijking pixelwaarde: {total_std:.4f}\\n\")\n",
    "\n",
    "for digit in range(10):\n",
    "    idx = np.where(y_train == digit)[0]\n",
    "    digit_pixels = x_train[idx]\n",
    "    mean_digit = np.mean(digit_pixels)\n",
    "    std_digit = np.std(digit_pixels)\n",
    "    print(f\"Cijfer {digit}: gemiddelde = {mean_digit:.4f}, stdev = {std_digit:.4f}\")\n",
    "\n",
    "plt.figure(figsize=(10,4))\n",
    "for digit in range(10):\n",
    "    idx = np.where(y_train == digit)[0]\n",
    "    mean_image = np.mean(x_train[idx], axis=0)\n",
    "    plt.subplot(2,5,digit+1)\n",
    "    plt.imshow(mean_image, cmap='gray')\n",
    "    plt.title(f\"{digit}\")\n",
    "    plt.axis('off')\n",
    "plt.suptitle(\"Gemiddelde afbeelding per cijfer\")\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "59283392",
   "metadata": {},
   "source": [
    "De gemiddelde pixelwaarde van de dataset is laag omdat de meeste pixels zwart zijn. Cijfers met meer wit oppervlak, zoals 0 of 8, hebben hogere gemiddelden dan smalle cijfers zoals 1. De gemiddelde afbeeldingen laten de typische vormen zien: het midden is lichter en de randen donkerder, en de wazige randen tonen de variatie in handschriften. De hoge standaardafwijking geeft het contrast aan tussen achtergrond en cijfer."
   ]
  },
  {
   "cell_type": "markdown",
   "id": "e122e79b",
   "metadata": {},
   "source": [
    "## Afbeelding met de grootste std"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 13,
   "id": "5e3befb1",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 640x480 with 1 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    }
   ],
   "source": [
    "(x_train, y_train), _ = mnist.load_data()\n",
    "x_train = x_train.astype('float32') / 255.0\n",
    "\n",
    "digit_stds = {digit: np.std(x_train[np.where(y_train == digit)[0]]) for digit in range(10)}\n",
    "\n",
    "max_std_digit = max(digit_stds, key=digit_stds.get)\n",
    "\n",
